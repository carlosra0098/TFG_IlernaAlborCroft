{
	"firestore": {
		"rules": "firestore.rules",
		"indexes": "firestore.indexes.json"
	},
	"hosting": {
		"public": "build/web",
		"ignore": [
			"firebase.json",
			"**/.*",
			"**/node_modules/**"
		],
		"rewrites": [
			{
				"source": "**",
				"destination": "/index.html"
			}
		]
	},
	"flutter": {
		"platforms": {
			"android": {
				"default": {
					"projectId": "syncro-1f9a6",
					"appId": "1:847934410234:android:c1f84cd5df40ab903da843",
					"fileOutput": "android/app/google-services.json"
				}
			},
			"dart": {
				"lib/firebase_options.dart": {
					"projectId": "syncro-1f9a6",
					"configurations": {
						"android": "1:847934410234:android:c1f84cd5df40ab903da843",
						"ios": "1:847934410234:ios:b73e76fc34bd21ea3da843"
					}
				}
			}
		}
	}
